+/// host stage-2 映射粒度直方图（按 1G/2M/4K 分桶统计页数）。
+pub struct HostS2LevelHist {
+    pub pages_4k: u64,
+    pub pages_2m: u64,
+    pub pages_1g: u64,
+    pub total: u64,
+}
+
+/// `kvm_pgtable_walk` 叶子回调：按映射粒度把页数累加到对应桶。
+///
+/// # Safety
+/// 由 `kvm_pgtable_walk` 在遍历 host stage-2 时调用；`ctx.arg` 指向调用者栈上的
+/// `HostS2LevelHist`，`ctx.ptep` 指向有效的页表项。
+unsafe extern "C" fn host_s2_level_walker(
+    ctx: *const kvm_pgtable_visit_ctx,
+    _visit: kvm_pgtable_walk_flags,
+) -> i32 {
+    if ctx.is_null() {
+        return 0;
+    }
+    let ctx_ref = ptr_wrapper_const!(ctx);
+
+    let hist_ptr = ctx_ref.arg as *mut HostS2LevelHist;
+    if hist_ptr.is_null() {
+        return 0;
+    }
+    // SAFETY: arg 指向调用者栈上的 HostS2LevelHist
+    let hist = unsafe { &mut *hist_ptr };
+
+    // SAFETY: 解引用 ptep
+    let pte = unsafe { *(ctx_ref.ptep) };
+    if !kvm_pte_valid(pte) {
+        return 0;
+    }
+
+    let granule = kvm_granule_size(ctx_ref.level);
+    let pages = granule >> PAGE_SHIFT;
+    hist.total += pages;
+    // 假定 4K 基页：4K=1<<PAGE_SHIFT、2M=0x20_0000、1G=0x4000_0000
+    if granule == 1u64 << PAGE_SHIFT {
+        hist.pages_4k += pages;
+    } else if granule == 0x20_0000 {
+        hist.pages_2m += pages;
+    } else if granule == 0x4000_0000 {
+        hist.pages_1g += pages;
+    }
+    0
+}
+
+/// 只读遍历 host stage-2（`host_mmu.pgt`），统计 1G/2M/4K 映射的页数分布。
+///
+/// 用于 C1 判别：munmap teardown 的 backend 停顿是否源于 host 内存被拆成 4K
+/// （4K 粒度下嵌套 stage-2 walk 更深、TLB 压力更大）。遍历期间持 host 组件锁。
+pub fn host_stage2_level_histogram() -> HostS2LevelHist {
+    let mut hist = HostS2LevelHist {
+        pages_4k: 0,
+        pages_2m: 0,
+        pages_1g: 0,
+        total: 0,
+    };
+    let mut walker = kvm_pgtable_walker {
+        cb: Some(host_s2_level_walker),
+        arg: &mut hist as *mut _ as *mut core::ffi::c_void,
+        flags: KVM_PGTABLE_WALK_LEAF,
+    };
+
+    host_lock_component();
+    // SAFETY: 访问可变静态 host_mmu 并调用 C 遍历函数；持 host 锁防遍历期间并发改表
+    let ret = unsafe {
+        let ia_bits = host_mmu.pgt.ia_bits;
+        kvm_pgtable_walk(&raw mut host_mmu.pgt, 0, 1u64 << ia_bits, &mut walker)
+    };
+    host_unlock_component();
+
+    if ret != 0 {
+        return HostS2LevelHist {
+            pages_4k: 0,
+            pages_2m: 0,
+            pages_1g: 0,
+            total: 0,
+        };
+    }
+    hist
+}
