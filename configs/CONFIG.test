# Minimal config for parser development — just enough to exercise diverse output formats.
OS="aarch64-Linux"
PROCESSORS="8"
MHZ="1900 MHz, 0.5263 nanosec clock"
TOTAL_MEM=28000
LINE_SIZE=64
MOTHERBOARD="Phytium D3000M"
NETWORKS=""
INFO=INFO.test
OUTPUT=/dev/null
ENOUGH=5000
TIMING_O=0
LOOP_O=0
SYNC_MAX=1
LMBENCH_SCHED="DEFAULT"
FILE=/tmp/lmb_file
FSDIR=/tmp/lmb_fs
MB=8
REMOTE=""
RSH=rsh
RCP=rcp
DISKS=""
DISK_DESC=""
SLOWFS="NO"
FASTMEM="YES"
MAIL=no
BENCHMARK_HARDWARE=NO
BENCHMARK_OS=
BENCHMARK_SYSCALL=YES
BENCHMARK_SIG=YES
BENCHMARK_PIPE=YES
BENCHMARK_CTX=YES
BENCHMARK_PAGEFAULT=YES
BENCHMARK_MEM=YES
BENCHMARK_UDP=YES
VERSION=3.0-a9
