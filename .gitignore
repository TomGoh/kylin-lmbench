# Build artifacts (regenerated by `make build`)
bin/

# Benchmark output (data; can be huge, environment-specific)
results/*
!results/.gitkeep
!results/Makefile
# Whitelist paper-grade datasets (raw evidence for n90-kvm-host/)
!results/precise-mmap/
!results/standalone-mem-bench/
!results/n90-day3/
# Within n90-day3, exclude the stochastic-outlier try1 dataset
# (rejected by try2 reproduction; pkvm-memory-access-speedup.md DEPRECATED)
results/n90-day3/n90-pkvm-noLSM-try1-*

# Extracted at runtime by scripts/lmbench
src/webpage-lm/

# Session memory / scratch
.remember/

# Editor / OS noise
*.swp
*.swo
.DS_Store
*~
guest/crosvm
guest/rootfs.img
/crosvm
