# Local benchmark/test logs and transient command output.
*.log
*.err
*.out
*.tmp
*.pid

# Result logs under results/ are source data for this repo.
!results/**/*.log
!results/**/*.err
!results/**/*.out
!results/**/*.txt
!results/**/*.csv

# Extracted at runtime by scripts/lmbench
src/webpage-lm/

# Session memory / scratch
.remember/

# Editor / OS noise
*.swp
*.swo
.DS_Store
*~
guest/crosvm
guest/rootfs.img
/crosvm
